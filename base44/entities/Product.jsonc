{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "category": {
      "type": "string",
      "enum": [
        "bebidas",
        "cocktails",
        "comida",
        "sobremesas"
      ]
    },
    "image_url": {
      "type": "string"
    },
    "available": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "price",
    "category"
  ]
}